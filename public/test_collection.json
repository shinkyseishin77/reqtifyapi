{
  "info": {
    "name": "Sample API Collection",
    "description": "A sample collection for testing import",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "my-global-token" }
    ]
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/users",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["users"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "https://jsonplaceholder.typicode.com/users",
              "protocol": "https",
              "host": ["jsonplaceholder", "typicode", "com"],
              "path": ["users"]
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Get Posts",
          "request": {
            "method": "GET",
            "url": "https://jsonplaceholder.typicode.com/posts"
          }
        },
        {
          "name": "Create Post (Form)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "title", "value": "Test Post" },
                { "key": "body", "value": "This is a test" },
                { "key": "userId", "value": "1" }
              ]
            },
            "url": "https://jsonplaceholder.typicode.com/posts"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com",
        "auth": {
          "type": "basic",
          "basic": [
            { "key": "username", "value": "admin" },
            { "key": "password", "value": "secret" }
          ]
        }
      }
    }
  ]
}
